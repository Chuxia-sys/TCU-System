# ⚠️ DO NOT set DATABASE_URL to a SQLite path.
# This project uses Firebase Firestore exclusively via src/lib/db.ts
# The system may override this at runtime; next.config.ts enforces file:/dev/null.
DATABASE_URL=file:/dev/null

# Firebase Admin SDK service account
# If not set, the system auto-discovers the JSON file in the project root
# FIREBASE_SERVICE_ACCOUNT_PATH=./for-commissions-firebase-adminsdk-fbsvc-c6f1245355.json

# Optional: API key for external cron services to trigger /api/cleanup
# Generate a random string and set it here. Then configure your cron provider
# to send it as a Bearer token: Authorization: Bearer <value>
# CLEANUP_API_KEY=your-generated-secret-key
