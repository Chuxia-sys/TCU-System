# ============================================================
# TCU Scheduling System - Environment Configuration
# ============================================================
# Database: Firebase Firestore (NOT SQLite/Prisma)
#
# ⚠️  CRITICAL: The system environment may set DATABASE_URL to
#     a SQLite path (e.g., file:/home/z/my-project/db/custom.db).
#     This OVERRIDES the value below. However, the application
#     has MULTIPLE layers of protection to prevent SQLite usage:
#
#     1. next.config.ts — overrides DATABASE_URL to /dev/null at startup
#     2. src/lib/db.ts — runtime guard neutralizes DATABASE_URL on import
#     3. prisma/schema.prisma — datasource hardcoded to file:/dev/null
#     4. src/lib/prisma-adapter.ts — hijacks any PrismaClient usage
#     5. db/custom.db — deleted; no SQLite file exists
#
# All actual database operations go through Firebase Firestore REST API.
# The DATABASE_URL below is a placeholder and is NEVER used at runtime.
# ============================================================

# Placeholder for Prisma schema (not used at runtime — see guards above)
DATABASE_URL=file:/dev/null

# Firebase / Firestore Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBjw0HlEGRRLJ3EoFzhIkve-pFm__-qNM0Q
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=for-commission.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=for-commission
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=for-commission.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=985895868624
NEXT_PUBLIC_FIREBASE_APP_ID=1:985895868624:web:3a41e2a7f875736258a6d5
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-YP7XL79XZS

# Firebase Auth (Server-side service account)
# NOTE: These are no longer used by the Firestore REST API adapter
# (which now uses API key authentication), but kept for reference.
FIREBASE_SERVICE_EMAIL=fepc-admin@for-commission.firebaseapp.com
FIREBASE_SERVICE_PASSWORD=fepc-admin-2024

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=tcu-scheduling-system-premium-secret-key-2024
